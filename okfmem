#!/usr/bin/env python3
"""okfmem — thin CLI dispatcher for the memory engine.

Usage:
  okfmem backfill    [--dry-run] [--store PATH]  # P1: stamp decay frontmatter
  okfmem init        [--dry-run] [--status] ...  # P2: pointers + registry
  okfmem consolidate [--dry-run] ...             # P3: decay + archive + push
  okfmem sync        -m "<msg>" [--no-push] ...  # commit + pull-rebase + push
  okfmem status                                  # alias for `init --status`

Core subcommands map to the memory_*.py modules living beside this script. Store
is resolved by each module: --store, else $OKFMEM_STORE, else ~/okfmem-store.

OPT-IN plugins live in plugins/memory_<cmd>.py and route lazily — the core map
stays harness-agnostic, so an unknown command loads a plugin only if that file
exists. Session search (issue #2) ships this way:
  okfmem index  [--rebuild]        # build FTS5 index over harness transcripts
  okfmem search "<query>"          # query it (off-prompt)
"""
import os
import runpy
import sys

HERE = os.path.dirname(os.path.realpath(__file__))  # realpath: resolve symlink -> real engine dir
MODULES = {"backfill": "memory_backfill.py", "init": "memory_init.py",
           "consolidate": "memory_consolidate.py", "sync": "memory_sync.py"}
# Opt-in plugin commands -> plugins/<file>. Loaded ONLY if the file is present,
# so core install stays harness-agnostic. Several commands may share one plugin.
PLUGINS = {"index": "memory_search.py", "search": "memory_search.py"}


def main():
    argv = sys.argv[1:]
    if not argv or argv[0] in ("-h", "--help"):
        print(__doc__)
        sys.exit(0)

    cmd, rest = argv[0], argv[1:]
    if cmd == "status":
        cmd, rest = "init", ["--status"] + rest

    if cmd in MODULES:
        target = os.path.join(HERE, MODULES[cmd])
    elif cmd in PLUGINS and os.path.exists(os.path.join(HERE, "plugins", PLUGINS[cmd])):
        # keep the subcommand token so the plugin's own parser sees `index`/`search`
        target = os.path.join(HERE, "plugins", PLUGINS[cmd])
        rest = [cmd] + rest
    else:
        print(f"okfmem: unknown command '{cmd}'\n{__doc__}", file=sys.stderr)
        sys.exit(2)

    sys.argv = [os.path.basename(target)] + rest
    runpy.run_path(target, run_name="__main__")


if __name__ == "__main__":
    main()
